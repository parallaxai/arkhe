{
  "name": "@arkhe/monorepo",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/parallaxai/arkhe.git"
  },
  "bugs": {
    "url": "https://github.com/parallaxai/arkhe/issues"
  },
  "homepage": "https://github.com/parallaxai/arkhe#readme",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "check-exports": "turbo run check-exports",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "dev": "turbo run dev",
    "format": "biome format --write .",
    "knip": "knip",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky",
    "release": "turbo run build --filter='./packages/*' && changeset publish",
    "syncpack:check": "syncpack lint",
    "syncpack:fix": "syncpack fix-mismatches && syncpack format",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "2.30.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "husky": "9.1.7",
    "knip": "6.3.0",
    "lint-staged": "16.4.0",
    "syncpack": "14.3.0",
    "turbo": "2.9.4",
    "typescript": "6.0.2"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "rollup": ">=4.59.0",
      "picomatch": ">=4.0.4",
      "vite": ">=7.3.2"
    },
    "auditConfig": {
      "ignoreCves": []
    }
  }
}
