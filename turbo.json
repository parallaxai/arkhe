{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "biome.json",
    ".syncpackrc.json",
    "packages/config/tsconfig/**",
    "packages/config/vitest.shared.ts",
    "packages/config/tsup.config.base.ts"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "check-exports": {
      "dependsOn": ["build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
