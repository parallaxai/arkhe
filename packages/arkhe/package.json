{
  "name": "arkhe",
  "version": "0.0.0",
  "description": "Arkhe core library",
  "license": "MIT",
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/parallaxai/arkhe.git",
    "directory": "packages/arkhe"
  },
  "bugs": {
    "url": "https://github.com/parallaxai/arkhe/issues"
  },
  "homepage": "https://github.com/parallaxai/arkhe#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "check-exports": "attw --pack && publint",
    "clean": "rm -rf dist .turbo coverage tsconfig.tsbuildinfo",
    "dev": "tsup --watch",
    "test": "vitest run --typecheck",
    "test:coverage": "vitest run --typecheck --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@arkhe/config": "workspace:*",
    "@vitest/coverage-v8": "4.1.5",
    "publint": "0.3.18",
    "tsup": "8.5.1",
    "vitest": "4.1.5"
  }
}
