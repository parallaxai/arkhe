# Auto detect text files and normalize line endings (LF in repo, OS-native on checkout)
* text=auto

# Force LF for shell-like files (husky hooks have no extension)
*.sh text eol=lf
.husky/* text eol=lf

# Force LF for config files commonly edited cross-platform
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
